{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build project (Ant)",
			"type": "shell",
			"command": "ant",
			"args": [
				"-f",
				"build.xml"
			],
			"group": "build"
		},
		{
			"label": "Build project (Maven)",
			"type": "shell",
			"command": "bash -c 'mvn compile'",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				{
					"owner": "java",
					"fileLocation": "absolute",
					"pattern": {
						"regexp": "^\\[ERROR\\]\\s+(/.+\\.java):\\[(\\d+),(\\d+)\\]\\s+(.+)$",
						"file": 1,
						"line": 2,
						"column": 3,
						"message": 4
					}
				}
			],
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Package project (Maven)",
			"type": "shell",
			"command": "bash -c 'mvn package -DskipTests'",
			"group": "build",
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Run tests (Maven)",
			"type": "shell",
			"command": "bash -c 'mvn test'",
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"problemMatcher": [
				{
					"owner": "java",
					"fileLocation": "absolute",
					"pattern": {
						"regexp": "^\\[ERROR\\]\\s+(/.+\\.java):\\[(\\d+),(\\d+)\\]\\s+(.+)$",
						"file": 1,
						"line": 2,
						"column": 3,
						"message": 4
					}
				}
			],
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		}
	]
}